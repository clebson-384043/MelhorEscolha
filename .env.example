# Copia este arquivo para .env e preenche os valores reais (nunca commitar o .env)

# --- Pipeline ---
PDF_INPUT_DIR=pipeline/input              # PDFs do estoque regular
LISTA_MORTE_INPUT_DIR=pipeline/input_lista_morte  # PDF da Lista da Morte (tenant separado)
OUTPUT_JSON=pipeline/output/base.json     # saída local do parser (desenvolvimento)

# --- Supabase ---
SUPABASE_URL=https://<projeto>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=https://<host>/
EVOLUTION_API_KEY=<api_key>
EVOLUTION_INSTANCE=<nome_da_instancia>
WHATSAPP_DESTINO=<numero>@s.whatsapp.net
